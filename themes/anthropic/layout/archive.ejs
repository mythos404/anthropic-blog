<section class="archive">
  <div class="archive__header">
    <h1 class="archive__title">Latest updates</h1>
    <div class="archive__search-wrap">
      <span class="archive__search-icon">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </span>
      <input class="archive__search-input" id="js-archive-search" type="search" placeholder="Search" autocomplete="off" spellcheck="false">
    </div>
  </div>

  <div class="archive__layout">

    <div class="archive__left">
      <div class="archive__cols">
        <span>DATE</span>
        <span>CATEGORY</span>
        <span>TITLE</span>
      </div>
      <ul class="archive__list">
        <% page.posts.each(function(post){ %>
          <li class="archive__row"
              data-category="<%= post.categories.length ? post.categories.first().name : 'Uncategorized' %>"
              data-title="<%= post.title.toLowerCase() %>"
              data-date="<%= date(post.date, 'MMM D, YYYY').toLowerCase() %>">
            <a href="<%- url_for(post.path) %>">
              <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'MMM D, YYYY') %></time>
              <span class="archive__row-cat"><%= post.categories.length ? post.categories.first().name : 'Uncategorized' %></span>
              <span class="archive__row-title"><%= post.title %></span>
            </a>
          </li>
        <% }); %>
      </ul>
      <p class="archive__empty" id="js-archive-empty" style="display:none">No results found.</p>
    </div>

    <div class="archive__right">
      <div class="archive__preview" id="js-archive-preview" aria-hidden="true">
        <span class="archive__preview-cat" id="js-preview-cat"></span>
        <span class="archive__preview-title" id="js-preview-title"></span>
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var COLORS = {
    'Announcements': '#5A7060',
    'AI & Tools':    '#4A6375',
    'Tutorials':     '#6B5E7A',
    'TV & Film':     '#7A5650',
    'Thoughts':      '#7A6A56',
    'Uncategorized': '#6B6456'
  };

  var preview      = document.getElementById('js-archive-preview');
  var previewCat   = document.getElementById('js-preview-cat');
  var previewTitle = document.getElementById('js-preview-title');
  var rows         = document.querySelectorAll('.archive__row');
  var searchInput  = document.getElementById('js-archive-search');
  var emptyMsg     = document.getElementById('js-archive-empty');

  if (!preview || !rows.length) return;

  function activate(row) {
    var cat   = row.dataset.category;
    var color = COLORS[cat] || COLORS['Uncategorized'];
    preview.style.background = color;
    previewCat.textContent   = cat.toUpperCase();
    previewTitle.textContent = row.querySelector('.archive__row-title').textContent;
  }

  /* always show first row on load */
  activate(rows[0]);

  rows.forEach(function (row) {
    row.addEventListener('mouseenter', function () { activate(row); });
  });

  if (searchInput) {
    searchInput.addEventListener('input', function () {
      var q = this.value.trim().toLowerCase();
      var visible = 0;
      rows.forEach(function (row) {
        var match = !q ||
          row.dataset.title.includes(q) ||
          row.dataset.category.toLowerCase().includes(q) ||
          row.dataset.date.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      emptyMsg.style.display = visible ? 'none' : '';
      var vis = Array.prototype.filter.call(rows, function(r){ return r.style.display !== 'none'; });
      if (vis.length) activate(vis[0]);
    });
  }
})();
</script>
