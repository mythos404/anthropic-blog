<header class="site-header">
  <div class="site-header__inner">
    <a class="site-logo" href="<%- url_for('/') %>"><span class="logo-s">S</span><span class="logo-letter l1">A</span><span class="logo-letter l2">U</span><span class="logo-letter l3">L</span><span class="logo-letter l4">'</span><span class="logo-letter l5">S</span><span class="logo-letter l6">&nbsp;</span><span class="logo-letter l7">B</span><span class="logo-letter l8">L</span><span class="logo-letter l9">O</span><span class="logo-g">G</span></a>
    <nav class="site-nav">
      <a href="<%- url_for('/') %>">Home</a>
      <a href="<%- url_for('/archives/') %>">Archives</a>
      <a href="<%- url_for('/categories/') %>">Categories</a>
      <a href="<%- url_for('/about/') %>">About</a>
      <a href="<%- url_for('/links/') %>">Links</a>
      <button class="site-nav__random" id="js-random" aria-label="Go to a random post">Random</button>
    </nav>
    <script>
    (function(){
      var posts = <%- JSON.stringify(site.posts.map(function(p){ return p.path; })) %>;
      document.getElementById('js-random').addEventListener('click', function(){
        if (!posts.length) return;
        var path = posts[Math.floor(Math.random() * posts.length)];
        window.location.href = '/' + path;
      });
    })();
    </script>
  </div>
</header>
<script>
(function(){
  var h = document.querySelector('.site-header');
  window.addEventListener('scroll', function(){
    h.classList.toggle('is-scrolled', window.scrollY > 80);
  }, {passive: true});
})();
</script>
